# Lovable Cloud (Supabase) — frontend publishable values
# These are NOT secrets (anon key + project URL are exposed in the client bundle by design).
# Real values are auto-injected by Lovable; this file is a template only.
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# 한국투자증권 OpenAPI 시크릿은 Lovable Cloud → Secrets 에 저장하세요.
# 절대 .env에 두지 마세요. (Edge Function에서 Deno.env.get() 으로만 접근)
# - KIS_APP_KEY
# - KIS_APP_SECRET
# - KIS_CANO
# - KIS_ACNT_PRDT_CD
